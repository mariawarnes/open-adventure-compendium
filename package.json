    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.1.1",
    "astro": "^6.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "sanity": "^5.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "daisyui": "^5.5.19",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "tailwindcss": "^4.2.2"
