---
import Card from "@/components/Card.astro";
import CardGrid from "@/components/CardGrid.astro";
import PageTabs from "@/components/PageTabs.tsx";
import SinglePageHeader from "@/components/SinglePageHeader.astro";
import Layout from "@/layouts/Layout.astro";
import {
  getAdventure,
  getAdventuresList,
  getCharactersByAdventure,
  getLocationsByAdventure,
} from "@/utils/sanity/functions";
import type { Params } from "astro";

export async function getStaticPaths() {
  const adventures = await getAdventuresList();
  return adventures.map((adventure) => ({
    params: { adventureSlug: adventure.slug?.current },
  }));
}

const { adventureSlug } = Astro.params as Params;

if (!adventureSlug) {
  throw new Error("Missing adventure slug");
}

const adventure = await getAdventure(adventureSlug);
const characters = await getCharactersByAdventure(adventureSlug);
const locations = await getLocationsByAdventure(adventureSlug);

const recommendedLevels = (adventure.recommendedLevels ?? [])
  .map((level) => Number(level))
  .filter((level) => Number.isFinite(level));

const sections = [
  {
    id: "encounters",
    list: adventure.encounters ?? [],
    title: "Encounters",
    getHref: (item) =>
      `/adventure/${adventure.slug.current}/encounter/${item.slug.current}`,
  },
  {
    id: "locations",
    list: locations ?? [],
    title: "Locations",
    getHref: (item) =>
      `/adventure/${adventure.slug.current}/location/${item.slug.current}`,
  },
  {
    id: "characters",
    list: characters ?? [],
    title: "Characters",
    getHref: (item) =>
      `/adventure/${adventure.slug.current}/character/${item.slug.current}`,
  },
];
---

<Layout title={adventure.name}>
  <SinglePageHeader title={adventure.name}>
    <Fragment slot="subtitle">
      <p>
        {adventure.edition?.map((e) => e.name).join(", ")}
        {
          recommendedLevels.length > 0 && (
            <>
              {" "}
              &#x2022; Lvl {Math.min(...recommendedLevels)}&ndash;
              {Math.max(...recommendedLevels)}
            </>
          )
        }
        &#x2022;
        {adventure.duration}
      </p>

      <p>
        by
        {adventure.authors?.map((author) => author.name).join(", ")}
      </p>
    </Fragment>
  </SinglePageHeader>

  {sections.length > 0 && <PageTabs client:only sections={sections} />}

  <div id="content" class="my-2">
    {
      adventure.campaignGuide && (
        <section id="general" class="scroll-mt-24">
          <div class="grid gap-4 grid-cols-1 py-4 md:grid-cols-2 lg:grid-cols-4">
            <Card
              title="Campaign Guide"
              button={{
                url: adventure.campaignGuide,
                text: "Download",
              }}
            />
          </div>
        </section>
      )
    }

    {
      sections.length > 0 &&
        sections.map((section) => (
          <CardGrid
            getHref={section.getHref}
            title={section.title}
            list={section.list}
            type={section.id}
          />
        ))
    }
  </div>
</Layout>
