---
import Card from "@/components/Card.astro";
import CardGrid from "@/components/CardGrid.astro";
import SinglePageHeader from "@/components/SinglePageHeader.astro";
import Layout from "@/layouts/Layout.astro";
import {
  getAdventure,
  getAdventuresList,
  getCharactersByAdventure,
  getLocationsByAdventure,
} from "@/utils/sanity/functions";
import type { Params } from "astro";

export async function getStaticPaths() {
  const adventures = await getAdventuresList();
  return adventures.map((adventure) => ({
    params: { slug: adventure.slug?.current },
  }));
}

const { slug } = Astro.params as Params;

if (!slug) {
  throw new Error("Missing adventure slug");
}

const adventure = await getAdventure(slug);
const characters = await getCharactersByAdventure(slug);
const locations = await getLocationsByAdventure(slug);

const recommendedLevels = (adventure.recommendedLevels ?? [])
  .map((level) => Number(level))
  .filter((level) => Number.isFinite(level));

const sections = [
  { id: "encounters", list: adventure.encounters ?? [], title: "Encounters" },
  { id: "locations", list: locations ?? [], title: "Locations" },
  { id: "characters", list: characters ?? [], title: "Characters" },
] satisfies Array<{
  id: "encounters" | "locations" | "characters";
  title: string;
  list: Array<{ name?: string; slug?: { current?: string } }>;
}>;

const populatedSections = sections.filter((section) => section.list.length > 0);
---

<Layout title={adventure.name}>
  <SinglePageHeader title={adventure.name}>
    <Fragment slot="subtitle">
      <p>
        {adventure.edition?.map((e) => e.name).join(", ")}
        {
          recommendedLevels.length > 0 && (
            <>
              {" "}
              &#x2022; Lvl {Math.min(...recommendedLevels)}&ndash;
              {Math.max(...recommendedLevels)}
            </>
          )
        }
        &#x2022;
        {adventure.duration}
      </p>

      <p>
        by
        {adventure.authors?.map((author) => author.name).join(", ")}
      </p>
    </Fragment>
  </SinglePageHeader>

  {
    populatedSections.length > 0 && (
      <div
        id="adventure-tabs"
        role="tablist"
        class="tabs tabs-box sticky top-0 z-10 lg:hidden"
      >
        {populatedSections.map((section) => (
          <a
            role="tab"
            class="tab"
            href={`#${section.id}`}
            aria-selected="false"
          >
            {section.title}
          </a>
        ))}
      </div>
    )
  }

  <div id="content" class="my-2">
    {
      adventure.campaignGuide && (
        <section id="general" class="scroll-mt-24">
          <div class="grid gap-4 grid-cols-1 py-4 md:grid-cols-2 lg:grid-cols-4">
            <Card
              title="Campaign Guide"
              button={{
                url: adventure.campaignGuide,
                text: "Download",
              }}
            />
          </div>
        </section>
      )
    }

    {
      populatedSections.map((section) => (
        <CardGrid
          urlPrefix="adventure"
          title={section.title}
          list={section.list}
          type={section.id}
        />
      ))
    }
  </div>
</Layout>

<script>
  const tabs = document.getElementById("adventure-tabs");
  const tabLinks = Array.from(tabs?.querySelectorAll("a.tab") ?? []);
  const sections = tabLinks
    .map((tab) => tab.getAttribute("href")?.slice(1))
    .filter((sectionId): sectionId is string => Boolean(sectionId))
    .map((sectionId) => document.getElementById(sectionId))
    .filter(
      (section): section is HTMLElement => section instanceof HTMLElement,
    );

  const setActiveTab = (sectionId: string) => {
    tabLinks.forEach((tab) => {
      const isActive = tab.getAttribute("href") === `#${sectionId}`;
      tab.classList.toggle("tab-active", isActive);
      tab.setAttribute("aria-selected", String(isActive));
    });
  };

  const updateActiveTab = () => {
    if (!tabs || sections.length === 0) return;

    const activationOffset = tabs.getBoundingClientRect().height - 5;
    let activeSection = sections[0];

    sections.forEach((section) => {
      if (section.getBoundingClientRect().top <= activationOffset) {
        activeSection = section;
      }
    });

    setActiveTab(activeSection.id);
  };

  tabs?.addEventListener("click", (event) => {
    const clickedTab =
      event.target instanceof Element ? event.target.closest("a.tab") : null;

    if (!(clickedTab instanceof HTMLAnchorElement)) return;

    const sectionId = clickedTab.getAttribute("href")?.slice(1);

    if (!sectionId) return;

    setActiveTab(sectionId);
  });

  window.addEventListener("scroll", updateActiveTab, { passive: true });
  window.addEventListener("resize", updateActiveTab);
  updateActiveTab();
</script>
