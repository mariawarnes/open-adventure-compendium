---
import SinglePageHeader from "@/components/SinglePageHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { getEncounter } from "@/utils/sanity/functions";
import type { Params } from "astro";

export const prerender = false;

const { slug } = Astro.params as Params;

if (!slug) {
  throw new Error("Missing encounter slug");
}

const encounter = await getEncounter(slug);
---

<Layout title={encounter.name || ""}>
  <SinglePageHeader title={encounter.name || ""} />
</Layout>
