---
export const prerender = false;

import SearchFilter from "@/components/SearchFilter.astro";
import Layout from "@/layouts/Layout.astro";
import "@/styles/global.css";

import {
  getAdventuresList,
  getAuthorsList,
  getDurationList,
  getEditionsList,
  getSystemsList,
} from "@/utils/sanity/functions";
import type {
  Adventure,
  AdventureDuration,
  AdventureFilters,
  AdventureOptions,
  AdventurePartySize,
  AdventureRecommendedLevel,
} from "@/utils/sanity/types";

const getSelectedValues = (name: string) =>
  Astro.url.searchParams
    .getAll(name)
    .map((value) => value.trim())
    .filter(Boolean);

const selectedAuthors = getSelectedValues("author");
const selectedEditions = getSelectedValues("edition");
const selectedSystems = getSelectedValues("system");
const selectedDuration = Astro.url.searchParams.get("duration")?.trim() ?? "";
const selectedLevels = getSelectedValues(
  "level",
) as AdventureRecommendedLevel[];
const selectedPartySizes = getSelectedValues(
  "partySize",
) as AdventurePartySize[];

const filters: AdventureFilters = {
  selectedAuthors,
  selectedEditions,
  selectedSystems,
  selectedDuration: selectedDuration
    ? [selectedDuration as AdventureDuration]
    : [],
  selectedLevels,
  selectedPartySizes,
};

const [authors, systems, editions, duration, adventures] = await Promise.all([
  getAuthorsList(),
  getSystemsList(),
  getEditionsList(),
  getDurationList(),
  getAdventuresList(filters),
]);

const options: AdventureOptions = {
  authors,
  editions,
  systems,
  duration,
  levels: Array.from({ length: 20 }, (_, index) =>
    String(index + 1),
  ) as AdventureRecommendedLevel[],
  partySizes: Array.from({ length: 8 }, (_, index) =>
    String(index + 1),
  ) as AdventurePartySize[],
};
---

<Layout title="Home">
  <SearchFilter filters={filters} options={options} />

  {
    adventures.length === 0 ? (
      <p>No adventures match these filters.</p>
    ) : (
      <section>
        {adventures.map((adventure: Adventure) => (
          <div>
            <a href={`/adventure/${adventure.slug?.current}`}>
              {adventure.name}
            </a>
            <p>{adventure.duration}</p>
          </div>
        ))}
      </section>
    )
  }
</Layout>
