{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Astro: Server",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/astro/bin/astro.mjs",
      "args": ["dev", "--config", "astro.config.mjs"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true
    },
    {
      "name": "Astro: Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:4321",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    },
    {
      "name": "Astro: Full Stack",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/astro/bin/astro.mjs",
      "args": ["dev", "--config", "astro.config.mjs"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "webRoot": "${workspaceFolder}"
      }
    }
  ],
  "compounds": [
    {
      "name": "Astro: Server + Chrome",
      "configurations": ["Astro: Server", "Astro: Chrome"]
    }
  ]
}
